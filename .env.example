# OCI API key configuration
OCI_CONFIG_FILE="~/.oci/config"
OCI_PROFILE="DEFAULT"
OCI_REGION="us-ashburn-1"

# OCI Generative AI
OCI_COMPARTMENT_OCID="ocid1.compartment.oc1..replace_with_your_compartment_ocid"
OCI_EMBEDDING_MODEL="cohere.embed-v4.0"
OCI_EMBEDDING_DIMENSIONS="1024"
# Optional. If omitted, the OCI SDK uses the region endpoint.
# GENAI_ENDPOINT="https://inference.generativeai.us-ashburn-1.oci.oraclecloud.com"

# OCI Object Storage
BUCKET_NAME="your_image_bucket"
PREFIX="optional/object/prefix"
# Optional. If omitted, the script calls Object Storage get_namespace().
# OBJECT_STORAGE_NAMESPACE="your_namespace"

# Oracle 26ai / ADB
DB_USERNAME="DEMO_USER"
DB_PASSWORD="replace_with_db_password"
DB_CONNECTION_STRING="your_adb_service_name"
TNS_ADMIN="./wallet"
WALLET_LOCATION="./wallet"
WALLET_PASSWORD="replace_with_wallet_password_if_required"
DB_TABLE="DEMO_USER.IMAGE_VECTORS"
